rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // vip_users: readable by a signed-in user for their OWN email only
    // (so the app can show "VIP" badge). Writable only from the
    // Cloud Function / Firebase console (admin SDK bypasses rules) —
    // never directly from the browser, so users can't grant themselves VIP.
    match /vip_users/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }

    // quota: server-only (Cloud Function uses admin SDK, which bypasses
    // these rules entirely). No client access at all.
    match /quota/{doc} {
      allow read, write: if false;
    }
  }
}

